    "/api/productos/": {
      "get": {
        "tags": ["Productos"],
        "summary": "Listar todos los productos",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Lista de productos",
            "schema": { "type": "array", "items": { "$ref": "#/definitions/Producto" } }
          },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "post": {
        "tags": ["Productos"],
        "summary": "Crear un producto",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "body", "in": "body", "required": true,
            "schema": {
              "type": "object",
              "required": ["categoria_id", "nombre", "precio_venta"],
              "properties": {
                "categoria_id":  { "type": "integer", "example": 1 },
                "proveedor_id":  { "type": "integer", "example": 1 },
                "nombre":        { "type": "string",  "example": "Televisor Samsung 55\"" },
                "descripcion":   { "type": "string",  "example": "Smart TV 4K" },
                "precio_compra": { "type": "number",  "example": 1500000 },
                "precio_venta":  { "type": "number",  "example": 2200000 },
                "stock_actual":  { "type": "integer", "example": 10 },
                "stock_minimo":  { "type": "integer", "example": 2 }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Producto creado" },
          "400": { "description": "Faltan campos obligatorios" },
          "401": { "description": "Token no proporcionado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },
    "/api/productos/{id}": {
      "get": {
        "tags": ["Productos"],
        "summary": "Obtener un producto por ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer", "example": 1 }
        ],
        "responses": {
          "200": { "description": "Producto encontrado", "schema": { "$ref": "#/definitions/Producto" } },
          "401": { "description": "Token no proporcionado" },
          "404": { "description": "Producto no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      },
