{
  "swagger": "2.0",
  "info": {
    "title": "RematesPaisa API",
    "description": "API REST para la plataforma RematesPaisa. Use el botón **Authorize** (🔒) para ingresar su token JWT y ejecutar los endpoints protegidos.",
    "version": "1.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": ["http"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "in": "header",
      "name": "Authorization",
      "description": "Ingrese el token en el formato: **Bearer &lt;token&gt;**. Obtenga el token en POST /api/usuarios/login."
    }
  },
  "definitions": {
    "Usuario": {
      "type": "object",
      "properties": {
        "id_usuario":       { "type": "integer", "example": 1 },
        "rol_id":           { "type": "integer", "example": 1 },
        "nombre":           { "type": "string",  "example": "Admin Principal" },
        "email":            { "type": "string",  "example": "admin@rematespaisa.com" },
        "numero_documento": { "type": "string",  "example": "123456789" },
        "activo":           { "type": "integer", "example": 1 },
        "rol_nombre":       { "type": "string",  "example": "Administrador" }
      }
    },
    "Rol": {
      "type": "object",
      "properties": {
        "id_rol":     { "type": "integer", "example": 1 },
        "nombre":     { "type": "string",  "example": "Administrador" },
        "descripcion":{ "type": "string",  "example": "Acceso total al sistema" }
      }
    },
    "Categoria": {
      "type": "object",
      "properties": {
        "id_categoria": { "type": "integer", "example": 1 },
        "nombre":       { "type": "string",  "example": "Electrodomésticos" },
        "descripcion":  { "type": "string",  "example": "Artículos para el hogar" }
      }
    },
    "Proveedor": {
      "type": "object",
      "properties": {
        "id_proveedor": { "type": "integer", "example": 1 },
        "nit":          { "type": "string",  "example": "900123456-1" },
        "nombre":       { "type": "string",  "example": "Distribuidora XYZ" },
        "telefono":     { "type": "string",  "example": "3001234567" },
        "correo":       { "type": "string",  "example": "ventas@xyz.com" },
        "direccion":    { "type": "string",  "example": "Calle 10 #20-30, Medellín" }
      }
    },
    "Producto": {
      "type": "object",
      "properties": {
        "id_producto":      { "type": "integer", "example": 1 },
        "categoria_id":     { "type": "integer", "example": 1 },
        "proveedor_id":     { "type": "integer", "example": 1 },
        "nombre":           { "type": "string",  "example": "Nevera LG 350L" },
        "descripcion":      { "type": "string",  "example": "Nevera de 350 litros, color plateado" },
        "precio_compra":    { "type": "number",  "example": 800000 },
        "precio_venta":     { "type": "number",  "example": 1200000 },
        "stock_actual":     { "type": "integer", "example": 15 },
        "stock_minimo":     { "type": "integer", "example": 3 },
        "activo":           { "type": "integer", "example": 1 },
        "categoria_nombre": { "type": "string",  "example": "Electrodomésticos" },
        "proveedor_nombre": { "type": "string",  "example": "Distribuidora XYZ" }
      }
    },
    "Pedido": {
      "type": "object",
      "properties": {
        "id_pedido":    { "type": "integer", "example": 1 },
        "usuario_id":   { "type": "integer", "example": 2 },
        "estado":       { "type": "string",  "example": "pendiente" },
        "total":        { "type": "number",  "example": 250000 },
        "fecha_pedido": { "type": "string",  "example": "2024-04-20T10:00:00.000Z" }
      }
    },
    "Factura": {
      "type": "object",
      "properties": {
        "id_factura":      { "type": "integer", "example": 1 },
        "pedido_id":       { "type": "integer", "example": 1 },
        "numero_factura":  { "type": "string",  "example": "FAC-0001" },
        "fecha_emision":   { "type": "string",  "example": "2024-04-20T10:05:00.000Z" },
        "total":           { "type": "number",  "example": 250000 }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "properties": {
        "message": { "type": "string", "example": "Acceso denegado. No se proporcionó un token." }
      }
    }
  },
  "paths": {
    "/api/usuarios/login": {
      "post": {
        "tags": ["Autenticación"],
        "summary": "Iniciar sesión",
        "description": "Autentica al usuario y devuelve el token JWT en una cookie httpOnly segura. Use los datos del usuario devueltos para la interfaz. **Copie el token desde la cookie o la respuesta para usar el botón Authorize.**",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["email", "password"],
              "properties": {
                "email":    { "type": "string", "example": "admin@rematespaisa.com" },
                "password": { "type": "string", "example": "admin123" }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Login exitoso. Token emitido en cookie httpOnly.",
            "schema": {
              "type": "object",
              "properties": {
                "message": { "type": "string", "example": "¡Inicio de sesión exitoso!" },
                "user":    { "$ref": "#/definitions/Usuario" }
              }
            }
          },
          "401": { "description": "Credenciales incorrectas", "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "403": { "description": "Cuenta inactiva",          "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "500": { "description": "Error interno del servidor","schema": { "$ref": "#/definitions/ErrorResponse" } }
        }
      }
    },
    "/api/usuarios/logout": {
      "post": {
        "tags": ["Autenticación"],
        "summary": "Cerrar sesión",
        "description": "Limpia la cookie httpOnly del servidor, cerrando la sesión del usuario.",
        "responses": {
          "200": { "description": "Sesión cerrada correctamente" }
        }
      }
    },
    "/api/usuarios/roles": {
      "get": {
        "tags": ["Usuarios"],
        "summary": "Listar todos los roles disponibles",
        "responses": {
          "200": {
            "description": "Lista de roles",
            "schema": { "type": "array", "items": { "$ref": "#/definitions/Rol" } }
          },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },
    "/api/usuarios/": {
      "get": {
        "tags": ["Usuarios"],
        "summary": "Listar todos los usuarios",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "Authorization", "in": "header", "type": "string", "description": "Bearer {token}" }
        ],
        "responses": {
          "200": {
            "description": "Lista de usuarios",
            "schema": { "type": "array", "items": { "$ref": "#/definitions/Usuario" } }
          },
          "401": { "description": "Token no proporcionado",  "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "403": { "description": "Token inválido",          "schema": { "$ref": "#/definitions/ErrorResponse" } },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "post": {
        "tags": ["Usuarios"],
        "summary": "Crear un nuevo usuario",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["rol_id", "nombre", "email", "password"],
              "properties": {
                "rol_id":           { "type": "integer", "example": 2 },
                "nombre":           { "type": "string",  "example": "Carlos Pérez" },
                "email":            { "type": "string",  "example": "carlos@ejemplo.com" },
                "password":         { "type": "string",  "example": "miPassword123" },
                "numero_documento": { "type": "string",  "example": "987654321" }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Usuario creado exitosamente" },
          "400": { "description": "Faltan campos obligatorios" },
          "401": { "description": "Token no proporcionado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },
    "/api/usuarios/{id}": {
      "get": {
        "tags": ["Usuarios"],
        "summary": "Obtener un usuario por ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer", "example": 1 }
        ],
        "responses": {
          "200": { "description": "Usuario encontrado", "schema": { "$ref": "#/definitions/Usuario" } },
          "401": { "description": "Token no proporcionado" },
          "404": { "description": "Usuario no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "put": {
        "tags": ["Usuarios"],
        "summary": "Actualizar un usuario",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer", "example": 1 },
          {
            "name": "body", "in": "body", "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "nombre":           { "type": "string",  "example": "Carlos Actualizado" },
                "email":            { "type": "string",  "example": "carlos.nuevo@ejemplo.com" },
                "numero_documento": { "type": "string",  "example": "111222333" },
                "activo":           { "type": "integer", "example": 1 }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Usuario actualizado correctamente" },
          "401": { "description": "Token no proporcionado" },
          "404": { "description": "Usuario no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "delete": {
        "tags": ["Usuarios"],
        "summary": "Eliminar un usuario",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer", "example": 1 }
        ],
        "responses": {
          "200": { "description": "Usuario eliminado" },
          "400": { "description": "No se puede eliminar: tiene registros asociados" },
          "401": { "description": "Token no proporcionado" },
          "404": { "description": "Usuario no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },
    "/api/roles/": {
      "get": {
        "tags": ["Roles"],
        "summary": "Listar todos los roles",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Lista de roles",
            "schema": { "type": "array", "items": { "$ref": "#/definitions/Rol" } }
          },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "post": {
        "tags": ["Roles"],
        "summary": "Crear un rol",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "body", "in": "body", "required": true,
            "schema": {
              "type": "object",
              "required": ["nombre"],
              "properties": {
                "nombre":      { "type": "string", "example": "Vendedor" },
                "descripcion": { "type": "string", "example": "Puede gestionar ventas" }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Rol creado" },
          "400": { "description": "Faltan campos obligatorios" },
          "401": { "description": "Token no proporcionado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },
    "/api/roles/{id}": {
      "get": {
        "tags": ["Roles"],
        "summary": "Obtener un rol por ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer", "example": 1 }
        ],
        "responses": {
          "200": { "description": "Rol encontrado", "schema": { "$ref": "#/definitions/Rol" } },
          "401": { "description": "Token no proporcionado" },
          "404": { "description": "Rol no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "put": {
        "tags": ["Roles"],
        "summary": "Actualizar un rol",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer", "example": 1 },
          {
            "name": "body", "in": "body", "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "nombre":      { "type": "string", "example": "Vendedor Senior" },
                "descripcion": { "type": "string", "example": "Puede gestionar ventas y reportes" }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Rol actualizado" },
          "401": { "description": "Token no proporcionado" },
          "404": { "description": "Rol no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "delete": {
        "tags": ["Roles"],
        "summary": "Eliminar un rol",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer", "example": 1 }
        ],
        "responses": {
          "200": { "description": "Rol eliminado" },
          "400": { "description": "No se puede eliminar: tiene usuarios asociados" },
          "401": { "description": "Token no proporcionado" },
          "404": { "description": "Rol no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },
    "/api/categorias/": {
      "get": {
        "tags": ["Categorías"],
        "summary": "Listar todas las categorías",
        "security": [{ "BearerAuth": [] }],
