                "descripcion": { "type": "string", "example": "Celulares, computadores y accesorios" }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Categoría creada" },
          "400": { "description": "Faltan campos obligatorios" },
          "401": { "description": "Token no proporcionado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },
    "/api/categorias/{id}": {
